# Required
OPENAI_API_KEY=your-openai-api-key

# Optional — Linear ticket context
LINEAR_API_KEY=your-linear-api-key

# Optional — GitHub code context
GITHUB_TOKEN=your-github-token
# GITHUB_REPO=owner/repo  # override auto-detected repo

# Optional — tuning
# ENHANCER_MODEL=gpt-4o-mini
# EXTRACTOR_MODEL=gpt-4o-mini
# MAX_TOKENS=1500
# TEMPERATURE=0.3
# CMD_TIMEOUT=8000
# SESSION_TTL=1800000
# MAX_CODE_FILES=8
# MAX_KEYWORDS=6
# MAX_FILE_HINTS=5
# SEARCH_EXTENSIONS=ts,tsx,js,jsx,py,go,rs,java,rb,php,swift,kt
# EXCLUDE_DIRS=node_modules,.git,dist,build,.next,vendor,__pycache__,.venv
# PORT=3000
